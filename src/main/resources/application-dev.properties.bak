#redis-cli --cluster create --cluster-replicas 1 127.0.0.1:6379 127.0.0.1:6380 127.0.0.1:7379 127.0.0.1:7380 127.0.0.1:8379 127.0.0.1:8380

#配置rocketmq
#启动命令，自动创建主题：start mqbroker.cmd -n 127.0.0.1:9876 autoCreateTopicEnable=true
rocketmq.name-server=localhost:9876
rocketmq.producer.group=my-producer-group
rocketmq.topic=topicA
rocketmq.tag=tagA

#配置kafka
#生成随机uuid：kafka-storage.bat random-uuid
#如果数据损坏，执行kafka-storage.bat format --standalone -t FvdqUaqyQjeCV589Kh7UhA -c ../../config/server.properties
#kafka的集群uuid---FvdqUaqyQjeCV589Kh7UhA
#创建topic命令kafka-topics.bat --create --bootstrap-server localhost:9092 --replication-factor 1 --partitions 1 --topic kafkaTopicA
#启动命令：进入到对应目录下打开命令行kafka-server-start.bat ../../config/server.properties
spring.kafka.bootstrap-servers=localhost:9092
spring.kafka.consumer.auto-offset-reset=earliest
