<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pzp.mapper.SharedingBookMapper">
	<resultMap id="resultBean" type="com.pzp.model.SharedingBook">
		<result property="userId" column="userId" javaType="long"></result>
		<result property="orderId" column="orderId" javaType="long"></result>
		<result property="name" column="name" javaType="java.lang.String"></result>
		<result property="numbers" column="numbers" javaType="java.lang.Integer"></result>
	</resultMap>
	
	<sql id="base_column">
		userId, orderId, name, numbers
	</sql>
	
	<sql id="insert_base_column">
		(userId, orderId, name, numbers)
	</sql>
	
	<insert id="addBook" parameterType="com.pzp.model.SharedingBook">
		insert into book
		<include refid="insert_base_column"></include>
		values(#{userId}, #{orderId}, #{name}, #{numbers})
	</insert>
	
</mapper>